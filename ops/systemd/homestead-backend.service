[Unit]
Description=Homestead Flask API
After=network.target

[Service]
WorkingDirectory=/opt/homestead-site/backend
EnvironmentFile=/opt/homestead-site/backend/.env
ExecStart=/opt/homestead-site/backend/.venv/bin/gunicorn "app.main:create_app()" --bind 127.0.0.1:8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

