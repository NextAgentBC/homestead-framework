FLASK_ENV=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://homestead_site:change-me@127.0.0.1:55433/homestead_site
CORS_ORIGINS=http://localhost:3000

SITE_NAME=Homestead
SITE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
SITE_INDUSTRY=education
SITE_AUDIENCE=students and independent creators
SITE_REGION=United States
# Live-chat assistant name. Blank = follows SITE_NAME (recommended). A rebrand
# updates it automatically, so the helper introduces itself as your brand.
SITE_ASSISTANT_NAME=

# First-boot demo seed: on an empty DB, populate a complete SITE_INDUSTRY home +
# About/Services pages so a fresh deploy is a real multi-page site, not a bare
# shell. Idempotent — skips once any content exists, so your data is never touched.
SITE_SEED_DEMO=true

# Industry-preview demo: lets anonymous visitors preview the site as any industry
# from the chat widget. The preview is per-visitor (cookie-scoped) and NEVER writes
# to the DB — your real site is untouched. Turn on only for a public showcase.
SITE_DEMO_PREVIEW=false

# i18n — comma-separated locales (first = default). Match the frontend's NEXT_PUBLIC_SITE_LOCALES.
SITE_LOCALES=en,zh
SITE_DEFAULT_LOCALE=en

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ADMIN_EMAILS=you@example.com

JWT_ISSUER=homestead-site
JWT_EXPIRES_HOURS=168

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DAILY_BLOG_AUTOPUBLISH=true

EMAIL_FROM=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your-google-app-password

# Website live chat (OPTIONAL) → answered by a tool-less assistant on the host
# webchat-bridge (see ops/webchat-bridge/). Leave WEBCHAT_BRIDGE_URL blank to run
# without a bridge: the widget still works as a lead-capture form. To enable AI
# replies, point it at your host bridge (e.g. http://host.docker.internal:18791)
# and match WEBCHAT_BRIDGE_TOKEN to ops/webchat-bridge/.env.
WEBCHAT_ENABLED=true
WEBCHAT_BRIDGE_URL=
WEBCHAT_BRIDGE_TOKEN=
